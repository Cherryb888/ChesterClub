{
  "expo": {
    "name": "ChesterClub",
    "slug": "ChesterClub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "chesterclub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90B8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chesterclub.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A90B8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.chesterclub.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "ChesterClub needs your camera to scan food and track nutrition."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ChesterClub needs access to your photos to analyze food images."
        }
      ]
    ]
  }
}
