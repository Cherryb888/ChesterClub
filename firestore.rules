rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Check if the requesting user is a friend of uid (used for feed access).
    // Reads from the friends subcollection — counts against Firestore read quota.
    function isFriend(uid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(uid));
    }

    // ─── User Private Data ─────────────────────────────────────────────────────
    // All subcollections under users/{uid} default to owner-only.

    match /users/{uid}/profile {
      allow read, write: if isOwner(uid);
    }

    // Friend code stored on the user's social sub-doc
    match /users/{uid}/profile/social {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/foodLogs/{date} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/waterLogs/{date} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/challenges {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/settings {
      allow read, write: if isOwner(uid);
    }

    // ─── Friends ───────────────────────────────────────────────────────────────
    // Owner can read their own list.
    // Both the owner AND the friend can write — needed for bidirectional
    // add (friendsService.ts writes to both users' subcollections in one call)
    // and bidirectional remove.

    match /users/{uid}/friends/{friendUid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) || isOwner(friendUid);
    }

    // ─── Activity Feed ─────────────────────────────────────────────────────────
    // Only the owner writes to their feed.
    // Friends (and the owner) can read — getFriendFeed() fetches each friend's
    // feed subcollection to build the combined timeline.

    match /users/{uid}/feed/{postId} {
      allow read:  if isOwner(uid) || isFriend(uid);
      allow write: if isOwner(uid);
    }

    // ─── Friend Codes ──────────────────────────────────────────────────────────
    // Any signed-in user can look up a code (needed to resolve addFriendByCode).
    // Only the user whose uid matches the stored uid field can create/modify.

    match /friendCodes/{code} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── Public Profiles ───────────────────────────────────────────────────────
    // Stores Chester level, mood, streak, achievement count.
    // Any signed-in user can read (needed for friend list stats and leaderboard).
    // Only the profile owner can write.

    match /publicProfiles/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid);
    }

  }
}
